# default compose file
# 在這裡的各種服務都不是建立在web server 而是建立在ubuntu虛擬機上，目的是更好的控管複雜架構與多項服務。且不影響網頁運行。
SERVICE_SERVER_IP=
WEB_SERVER_IP=
WINDOWS_EXPORT_PASSWORD=
MYSQL_ROOT_PASSWORD=
DB_BACKUP_USERNAME=
DB_BACKUP_PASSWORD=
K3S_TOKEN=
# sentry server
SENTRY_LARAVEL_DSN=https://<key>@sentry.yourdomain.com/<project-id>
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false

# monitor namespace (shared monitor-postgresql credentials)
MONITOR_DB_HOST=monitor-postgresql.monitor.svc.cluster.local
MONITOR_DB_PORT=5432
MONITOR_DB_SUPER_USER=postgres
MONITOR_DB_SUPER_PASSWORD=
MONITOR_DB_USERNAME=monitor_app
MONITOR_DB_PASSWORD=

# laravel pulse
PULSE_DB_CONNECTION=pulse
PULSE_DB_DATABASE=pulse
PULSE_REDIS_CONNECTION=pulse
PULSE_INGEST_DRIVER=redis
PULSE_REDIS_HOST=pulse-redis.monitor.svc.cluster.local
PULSE_REDIS_PORT=6379
PULSE_REDIS_PASSWORD=

# laravel telescope (dev-only)
TELESCOPE_ENABLED=true
TELESCOPE_DB_CONNECTION=telescope
